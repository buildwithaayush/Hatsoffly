# =============================================================================
# Hatsoffly — environment matrix (local · development · production)
# =============================================================================
# Copy to `.env` for local work:  cp .env.example .env
#
# Tier is set with NEXT_PUBLIC_APP_ENV (recommended on every deploy).
# Vercel: if unset, preview → development, production → production (see lib/env.ts).
#
# MOCK_INTEGRATIONS:
#   - Local only. In `development` and `production`, integrations are always real.
#   - On local, explicit 1/0 wins; if unset, mocks default to ON.
# =============================================================================

# --- Tier & URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="local"

NEXT_PUBLIC_SUPPORT_DOMAIN="hatsoffly.com"

# --- Database (PostgreSQL everywhere — required for Vercel/serverless) ---
# Neon / Supabase / RDS — use pooler URL on serverless when provider recommends it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

JWT_SECRET="generate-a-long-random-string-min-32-chars"

# Max session length per login (cookie maxAge + JWT exp). Default 30 days.
# While you use the app, `/api/v1/auth/me` can re-issue the cookie before expiry (rolling session).
# Lower this (e.g. 14) for stricter idle timeout; users still sign out immediately via Log out.
# SESSION_MAX_AGE_DAYS=30

# =============================================================================
# LOCAL — daily development
# =============================================================================
# Keep mocks on while building UI (verify code 123456). For real SMS + Places:
#   MOCK_INTEGRATIONS=0
#   + fill Twilio + GOOGLE_MAPS_API_KEY below

MOCK_INTEGRATIONS="1"
MOCK_VERIFY_CODE="123456"
# Optional override for outbound SMS only.
# - unset: if full Twilio Messaging creds are present, real SMS is used; otherwise follows MOCK_INTEGRATIONS
# - set "1": always mock outbound SMS
# - set "0": always use real outbound SMS (requires Twilio Messaging creds)
# MOCK_OUTBOUND_SMS="0"

# --- Phone signup/login (non-production; production is US/CA only) ---
# Development (e.g. Vercel Preview): US/CA + India (+91) — fully open; DEV_PHONE_ALLOWLIST is ignored.
# Local only: optional DEV_PHONE_ALLOWLIST narrows US/CA; +91 India still never needs listing.
# DEV_PHONE_ALLOWLIST="+14155552671"

# --- Google Maps (Places Autocomplete + Details) ---
# Enable “Places API” + billing on a GCP project. Restrict key by HTTP referrer + API.
# GOOGLE_MAPS_API_KEY=

# --- Twilio (required when MOCK_INTEGRATIONS=0) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=     # Verify → Services
# TWILIO_MESSAGING_FROM=         # E.164 SMS sender for post-verify test message (required for real mode)

# --- Owner alerts (private / low-star feedback) ---
# Email via Resend (https://resend.com). Without RESEND_API_KEY, emails log to the server console.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Hatsoffly <notifications@yourdomain.com>"
# SMS uses the same Twilio Messaging sender as above (MOCK_INTEGRATIONS=1 logs instead of sending).

# --- Google OAuth (optional; signup “Continue with Google”) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# =============================================================================
# DEVELOPMENT / STAGING (e.g. Vercel Preview or staging.yourdomain.com)
# =============================================================================
# NEXT_PUBLIC_APP_ENV="development"
# NEXT_PUBLIC_APP_URL="https://staging.hatsoffly.com"
# DATABASE_URL="postgresql://..."
# Integrations are always real in development (MOCK_INTEGRATIONS is ignored)
# …same integration keys as production but use Twilio trial / test numbers & GCP dev project

# =============================================================================
# PRODUCTION
# =============================================================================
# NEXT_PUBLIC_APP_ENV="production"
# NEXT_PUBLIC_APP_URL="https://hatsoffly.com"
# MOCK_INTEGRATIONS="0"
# Strong JWT_SECRET, Postgres DATABASE_URL, production Twilio + Maps keys
